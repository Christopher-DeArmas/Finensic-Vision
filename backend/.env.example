# ---- Database ----
# SQLAlchemy URL. Defaults to a local SQLite file in the backend directory.
DATABASE_URL=sqlite:///./sentinel.db

# ---- OpenAI (optional) ----
# If OPENAI_API_KEY is empty, Sentinel falls back to deterministic template
# summaries and SARs so the demo always works offline.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Streaming simulator ----
STREAM_MIN_TPS=2
STREAM_MAX_TPS=5

# ---- Risk / alerting ----
ALERT_THRESHOLD=40

# ---- Synthetic data ----
# Fixed RNG seed for reproducible data + planted scenarios.
SEED=42

# ---- CORS (frontend origins, comma-separated) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
